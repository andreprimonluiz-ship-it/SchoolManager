@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center mt-5">
    <h1 class="display-4 fw-bold">School Manager</h1>

    <p class="lead mt-3">
        Manage students, teachers and classrooms easily.
    </p>
</div>

<div class="container mt-5">
    <div class="row">

        <div class="col-md-4">
            <div class="card dashboard-card shadow-sm h-100">
                <div class="card-body text-center">
                    <h3>
                        <i class="bi bi-people-fill"></i>
                        Students
                    </h3>

                    <p>
                        Manage student information and classroom assignments.
                    </p>

                    <a asp-controller="Students"
                       asp-action="Index"
                       class="btn btn-primary">
                        Access
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card dashboard-card shadow-sm h-100">
                <div class="card-body text-center">
                    <h3>
                        <i class="bi bi-person-workspace"></i>
                        Teachers
                    </h3>

                    <p>
                        View and manage teachers and their classrooms.
                    </p>

                    <a asp-controller="Teachers"
                       asp-action="Index"
                       class="btn btn-success">
                        Access
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card dashboard-card shadow-sm h-100">
                <div class="card-body text-center">
                    <h3>
                        <i class="bi bi-door-open-fill"></i>
                        Classrooms
                    </h3>

                    <p>
                        Organize classrooms, schedules and students.
                    </p>

                    <a asp-controller="Classrooms"
                       asp-action="Index"
                       class="btn btn-warning">
                        Access
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="text-center mt-5 text-muted">
    <small>
        School Manager • ASP.NET Core MVC • Entity Framework Core
    </small>
</div>
