@model SchoolManager.Models.ViewModel.ClassroomFormViewModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Classroom</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Classroom.Id" />
            <div class="form-group">
                <label asp-for="Classroom.Name" class="control-label"></label>
                <input asp-for="Classroom.Name" class="form-control" />
                <span asp-validation-for="Classroom.Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Classroom.Capacity" class="control-label"></label>
                <input asp-for="Classroom.Capacity" class="form-control" />
                <span asp-validation-for="Classroom.Capacity" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Classroom.Shift" class="control-label"></label>
                <input asp-for="Classroom.Shift" class="form-control" />
                <span asp-validation-for="Classroom.Shift" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Classroom.Teacher" class="control-label"></label>
                <select asp-for="Classroom.TeacherId" asp-items="@(new SelectList(Model.Teachers, "Id", "Name"))" class="form-control"></select>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
