@model SchoolManager.Models.Teacher

@{
    ViewData["Title"] = "Teacher Details";
}

<h2>@ViewData["Title"]</h2>

<div class="card shadow-sm">

    <div class="card-header">
        <h4 class="mb-0">Teacher Information</h4>
    </div>

    <div class="card-body">

    <dl class="row">

        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class="col-sm-9">
            @Model.Name
        </dd>

        <dt class="col-sm-3">
            Classrooms
        </dt>
        <dd class="col-sm-9">
            @string.Join(", ", Model.Classrooms.Select(c => c.Name))
        </dd>
    </dl>
</div>
    <div class="card-footer">
        <div class="d-flex gap-2">
            <a asp-action="Edit"
               asp-route-id="@Model.Id"
               class="btn btn-primary">
                Edit
            </a>

            <a asp-action="Index"
               class="btn btn-secondary">
                Back
            </a>
        </div>