@model SchoolManager.Models.ViewModel.TeacherFormViewModel

@{
    ViewData["Title"] = "Create";
}

<h2 class="mb-4">@ViewData["Title"]</h2>

<div class="card shadow-sm">
    <div class="card-header">
        <h4 class="mb-0">Teacher</h4>
    </div>

    <div class="card-body">
        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Teacher.Name" class="form-label"></label>
                <input asp-for="Teacher.Name" class="form-control" />
                <span asp-validation-for="Teacher.Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Teacher.Email" class="form-label"></label>
                <input asp-for="Teacher.Email" class="form-control" />
                <span asp-validation-for="Teacher.Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Teacher.Phone" class="form-label"></label>
                <input asp-for="Teacher.Phone" class="form-control" />
                <span asp-validation-for="Teacher.Phone" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    Create
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Back
                </a>
            </div>
        </form>
    </div>
</div>


