@model IEnumerable<SchoolManager.Models.Teacher>

@{
    @using SchoolManager.Models.Enums
    ViewData["Title"] = "Teachers";
}

<h2 class="mb-4">@ViewData["Title"]</h2>

<div class="card shadow-sm">

    <div class="card-header d-flex justify-content-between align-items-center">
        <h4 class="mb-0">Teacher List</h4>

        <a asp-action="Create" class="btn btn-success">
            Create Teacher
        </a>
    </div>

    <div class="card-body">

        <div class="table-responsive">

            <table class="table table-striped table-hover align-middle">

                <thead class="table-dark">
                    <tr>
                        <th>
                            @Html.DisplayNameFor(model => model.Name)
                        </th>

                        <th>
                            Classrooms
                        </th>

                        <th class="text-center">
                            Actions
                        </th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>
                                @item.Name
                            </td>

                            <td>

                                @if (item.Classrooms.Any())
                                {
                                    @foreach (var classroom in item.Classrooms)
                                    {

                                        <span class="badge @classroom.Shift.GetBadgeClass()">
                                            @classroom.Name (@classroom.Shift)
                                        </span>

                                    }
                                }
                                else
                                {
                                    <span class="text-muted">
                                        No classrooms assigned
                                    </span>
                                }

                            </td>

                            <td class="text-center">

                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-primary">
                                    Edit
                                </a>

                                <a asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-secondary">
                                    Details
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-danger">
                                    Delete
                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>